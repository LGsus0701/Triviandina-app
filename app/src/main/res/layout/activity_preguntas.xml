<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtCategoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categoría:"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CRONÓMETRO ARRIBA DERECHA -->
    <TextView
        android:id="@+id/txtTiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FF0000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- IMAGEN DE LA PREGUNTA -->
    <ImageView
        android:id="@+id/imgPregunta"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtCategoria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PREGUNTA (DEBAJO DE LA IMAGEN) -->
    <TextView
        android:id="@+id/txtPregunta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Aquí va la pregunta..."
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imgPregunta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTÓN 1 -->
    <Button
        android:id="@+id/btnOp1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Opción 1"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtPregunta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTÓN 2 -->
    <Button
        android:id="@+id/btnOp2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Opción 2"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnOp1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTÓN 3 -->
    <Button
        android:id="@+id/btnOp3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Opción 3"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnOp2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTÓN 4 -->
    <Button
        android:id="@+id/btnOp4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Opción 4"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnOp3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
